// naive_queue.cvh
#ifndef NAIVE_QUEUE_H
#define NAIVE_QUEUE_H

struct _nqueue;
typedef struct _nqueue NQueue;


_Bool naive_enq(NQueue* queue, int value);

int naive_deq(NQueue* queue);

_Bool naive_queue_contains(NQueue* queue, int value);

int naive_queue_index(NQueue* queue, int index);

NQueue* naive_queue_create();

_Bool naive_queue_destroy(NQueue* queue); 

void naive_queue_print(NQueue* queue);

int naive_queue_size(NQueue* queue);

#endif
