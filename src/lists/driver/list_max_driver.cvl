void printOpInfo_list(int type, int tid, _Bool op, int val, int* results) {
  if (type == RESULT) {
    printf("[RESULT]");
  } else if (type == ACTUAL) {
    printf("[ACTUAL]");
  } else {
    printf("[PERMS%d]", type);
  }
  printf("\t Thread[%d] performs ", tid);
  printf((op==ADD?"<ADD>":"<DEL>"));
  printf(" value: %d", val);
  printList(results);
  printf("\n");
}

void printEquivSeqInfo(int* perms, int* results) {
  int step_counters[nthreads];

  for (int tid = 0; tid < nthreads; tid++)
    step_counters[tid] = 0;

  printf("[PASS]\t Equivalent sequential execution: \n");
  for (int step = 0; step < num_steps; step++) {
    int tid = perms[step];
    int step_local = step_counters[tid];
    _Bool op = ops[tid][step_local];
    int val = vals[tid][step_local];

    printOpInfo_list(RESULT, tid, op, val, results);
    step_counters[tid]++;
  }
}

void init() {
  num_vals = VAL_B + 1;
  num_steps = 0;
  
  for (int tid = 0; tid < nthreads; tid++) {
    int num_steps_local = $choose_int(STP_B+1-num_steps);
    
    nsteps[tid] = num_steps_local;
    for (int step = 0; step < num_steps_local; step++) {
      ops[tid][step] = (_Bool) $choose_int(2);
      vals[tid][step] = $choose_int(num_vals);
      num_steps++;
    }
  }
  num_perms = calc_num_perms(nthreads, nsteps);
}

void thread(int tid, List* list, int* results) {
  int num_steps_local = nsteps[tid];
  
  for (int step = 0; step < num_steps_local; step++) {
    _Bool op = ops[tid][step];
    int val = vals[tid][step];

    if (op == ADD) {
      list_add(list, val);
      $atomic {
	results[val]++;
      }
    } else {
      list_remove(list, val);
      $atomic {
	results[val]--;
      }
    }
    //printOpInfo_list(ACTUAL, tid, op, val, list);
  }
}

void permseq(int pid, int* perm, int* oracle_results) {
  int step_counters[nthreads];

  for (int tid = 0; tid < nthreads; tid++)
    step_counters[tid] = 0;

  for (int step_seq = 0; step_seq < num_steps; step_seq++) {
    int tid = perm[step_seq];
    int step = step_counters[tid];
    _Bool op = ops[tid][step];
    int val = vals[tid][step];

    if (op == ADD)
      oracle_results[val]++;
    else 
      oracle_results[val]--;
    step_counters[tid]++;
    //printOpInfo(pid, tid, op, val, oracle_results);
  }
}

_Bool isEqual(int* actual, int* oracle) {
  for (int val = 0; val < num_vals; val++)
    if (actual[val] != oracle[val])
      return false;
  return true;
}

int main() {
  init(); 
  printInitInfo();

  int pid = 0;
  int** perms = compute_perms(nthreads, nsteps);
  int actual_results[num_vals];
  int oracle_results[num_vals];
  List* actual_list = list_create();

  for (int val = 0; val < num_vals; val++)
    actual_results[val] = 0;

  $parfor (int tid : 0 .. nthreads-1) {
    thread(tid, actual_list, actual_results);
  }
  
  for (pid = 0; pid < num_perms; pid++) {
    for (int val = 0; val < num_vals; val++)
      oracle_results[val] = 0;
    permseq(pid, perms[pid], oracle_results);
    if (isEqual(actual_results, oracle_results) == true) {
      printEquivSeqInfo(perms[pid], oracle_results);
      break;
    }
  }
  if (num_steps > 0 && pid >= num_perms) {
    printf("[FAIL]\t No matching sequentialized execution found!\n");
    printf("[RESULT]\t Concurrent execution results:");
    printList(actual_results);
    printf("\n");
    $assert(false);
  }
  list_destroy(actual_list);
  for (int i = 0; i < num_perms; i++)
    free(perms[i]);
  free(perms);
}

